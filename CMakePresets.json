            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "Debug",
                "QPPJS_ENABLE_COVERAGE": "ON",
                "QPPJS_ENABLE_ASAN": "OFF",
                "QPPJS_WARNINGS_AS_ERRORS": "OFF"
            }
        },
        {
            "name": "macos-appleclang-debug",
