            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "macos-appleclang-coverage",
            "displayName": "macOS Apple Clang Coverage",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "QPPJS_ENABLE_COVERAGE": "ON",
                "QPPJS_ENABLE_ASAN": "OFF",
                "QPPJS_WARNINGS_AS_ERRORS": "OFF"
            }
        },
        {
            "name": "macos-llvmclang-debug",
            "displayName": "macOS LLVM Clang Debug",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "$env{LLVM_PREFIX}/bin/clang++",
                "CMAKE_BUILD_TYPE": "Debug",
                "QPPJS_ENABLE_ASAN": "ON",
                "CMAKE_EXE_LINKER_FLAGS": "-L$env{LLVM_PREFIX}/lib/c++",
                "CMAKE_MODULE_LINKER_FLAGS": "-L$env{LLVM_PREFIX}/lib/c++",
                "CMAKE_SHARED_LINKER_FLAGS": "-L$env{LLVM_PREFIX}/lib/c++"
            }
        },
        {
            "name": "macos-llvmclang-release",
            "displayName": "macOS LLVM Clang Release",
