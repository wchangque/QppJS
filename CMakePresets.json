                "CMAKE_CXX_COMPILER": "$env{LLVM_PREFIX}/bin/clang++",
                "CMAKE_BUILD_TYPE": "Debug",
                "QPPJS_ENABLE_COVERAGE": "ON",
                "QPPJS_ENABLE_ASAN": "OFF",
                "QPPJS_WARNINGS_AS_ERRORS": "OFF",
                "CMAKE_EXE_LINKER_FLAGS": "-L$env{LLVM_PREFIX}/lib/c++",
                "CMAKE_MODULE_LINKER_FLAGS": "-L$env{LLVM_PREFIX}/lib/c++",
                "CMAKE_SHARED_LINKER_FLAGS": "-L$env{LLVM_PREFIX}/lib/c++"
            }
        },
        {
            "name": "windows-msvc-debug",
            "displayName": "Windows MSVC Debug",
            "inherits": "base",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Debug"
            }
        },
        {
            "name": "windows-msvc-release",
            "displayName": "Windows MSVC Release",
