{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "linux-clang-debug",
            "displayName": "Linux Clang Debug",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "Debug",
                "QPPJS_ENABLE_ASAN": "ON"
            }
        },
        {
            "name": "linux-clang-coverage",
            "displayName": "Linux Clang Coverage",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "Debug",
                "QPPJS_ENABLE_COVERAGE": "ON",
                "QPPJS_WARNINGS_AS_ERRORS": "OFF"
            }
        },
        {
            "name": "linux-gcc-coverage",
            "displayName": "Linux GCC Coverage",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_BUILD_TYPE": "Debug",
                "QPPJS_ENABLE_COVERAGE": "ON",
                "QPPJS_WARNINGS_AS_ERRORS": "OFF"
            }
        },
        {
            "name": "macos-appleclang-debug",
            "displayName": "macOS Apple Clang Debug",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "QPPJS_ENABLE_ASAN": "ON"
            }
        },
        {
            "name": "macos-appleclang-coverage",
            "displayName": "macOS Apple Clang Coverage",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "QPPJS_ENABLE_COVERAGE": "ON",
                "QPPJS_WARNINGS_AS_ERRORS": "OFF"
            }
        },
        {
            "name": "windows-msvc-debug",
            "displayName": "Windows MSVC Debug",
            "inherits": "base",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "linux-clang-debug",
            "configurePreset": "linux-clang-debug"
        },
        {
            "name": "linux-clang-coverage",
            "configurePreset": "linux-clang-coverage"
        },
        {
            "name": "linux-gcc-coverage",
            "configurePreset": "linux-gcc-coverage"
        },
        {
            "name": "macos-appleclang-debug",
            "configurePreset": "macos-appleclang-debug"
        },
        {
            "name": "macos-appleclang-coverage",
            "configurePreset": "macos-appleclang-coverage"
        },
        {
            "name": "windows-msvc-debug",
            "configurePreset": "windows-msvc-debug",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "linux-clang-debug",
            "configurePreset": "linux-clang-debug",
            "output": {
                "outputOnFailure": true
            },
            "environment": {
                "ASAN_OPTIONS": "detect_leaks=0"
            }
        },
        {
            "name": "linux-clang-coverage",
            "configurePreset": "linux-clang-coverage",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-coverage",
            "configurePreset": "linux-gcc-coverage",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "macos-appleclang-debug",
            "configurePreset": "macos-appleclang-debug",
            "output": {
                "outputOnFailure": true
            },
            "environment": {
                "ASAN_OPTIONS": "detect_leaks=0"
            }
        },
        {
            "name": "macos-appleclang-coverage",
            "configurePreset": "macos-appleclang-coverage",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "windows-msvc-debug",
            "configurePreset": "windows-msvc-debug",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
